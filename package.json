{
  "name": "open-business-os",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first OSS business operating system MVP.",
  "type": "commonjs",
  "scripts": {
    "dev": "node apps/api/src/server.js",
    "dev:postgres": "OPEN_BUSINESS_OS_STORE=postgres node apps/api/src/server.js",
    "start": "node apps/api/src/server.js",
    "test:unit": "node --test tests/unit.mjs",
    "test:e2e": "node --test tests/e2e-mobile.mjs",
    "test:smoke": "node --test tests/smoke.mjs",
    "test:postgres": "OPEN_BUSINESS_OS_STORE=postgres BASE_URL=http://localhost:3000 node --test tests/smoke.mjs",
    "test": "node --test tests/unit.mjs",
    "verify": "npm run check && npm run test:unit && npm run test:e2e",
    "check": "node --check apps/api/src/server.js && node --check apps/web/public/app.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
