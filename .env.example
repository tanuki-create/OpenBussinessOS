PORT=3000
DATABASE_URL=postgres://open_business_os:open_business_os_dev@localhost:5432/open_business_os
OPEN_BUSINESS_OS_SECRET=change-me-for-local-dev
OPEN_BUSINESS_OS_STORE=json
OPEN_BUSINESS_OS_INIT_DB=1
OPEN_BUSINESS_OS_AUTH_MODE=local
# For OPEN_BUSINESS_OS_AUTH_MODE=token, either set a single default-user token:
OPEN_BUSINESS_OS_API_TOKEN=
# Or map tokens to user ids already present in users/workspace_memberships:
# OPEN_BUSINESS_OS_AUTH_TOKENS={"token-value":{"userId":"00000000-0000-4000-8000-000000000001"}}
OPEN_BUSINESS_OS_LIVE_LLM=0
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
OPEN_BUSINESS_OS_GITHUB_TOKEN=
# Use either OPEN_BUSINESS_OS_GITHUB_REPOSITORY=owner/repo or owner/repo split vars.
OPEN_BUSINESS_OS_GITHUB_REPOSITORY=
OPEN_BUSINESS_OS_GITHUB_OWNER=
OPEN_BUSINESS_OS_GITHUB_REPO=
